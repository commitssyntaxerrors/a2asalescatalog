{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "CatalogSearchRequest",
  "description": "Input schema for catalog.search skill",
  "type": "object",
  "required": ["skill", "q"],
  "properties": {
    "skill": { "const": "catalog.search" },
    "q": { "type": "string", "minLength": 1, "maxLength": 500, "description": "Free-text search query" },
    "max": { "type": "integer", "minimum": 1, "maximum": 50, "default": 10, "description": "Max results to return" },
    "cat": { "type": "string", "description": "Category ID filter" },
    "price_min": { "type": "integer", "minimum": 0, "description": "Minimum price in cents" },
    "price_max": { "type": "integer", "minimum": 0, "description": "Maximum price in cents" },
    "sort": { "type": "string", "enum": ["relevance", "price_asc", "price_desc", "rating"], "default": "relevance" },
    "vendor": { "type": "string", "description": "Filter by vendor domain" }
  },
  "additionalProperties": false
}
